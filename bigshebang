  The password is NOT stored in the archive. Data cannot be recovered
  without the correct password.

REQUIREMENTS:
  - openssl (for AES-256-CBC encryption)
  - tar (for archiving)
  - base64 (for encoding)
  - Compression tool matching selected type (gzip/bzip2/xz/zstd)

HELP
    exit 0
}

# Parse command line arguments
parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -c|--compress)
                COMPRESS_TYPE="$2"
                shift 2
                ;;
            -e|--encrypt)
                ENCRYPT=1
                shift
                ;;
            -p|--password)
                PASSWORD="$2"
                ENCRYPT=1
                shift 2
                ;;
            -o|--output)
                OUTPUT_FILE="$2"
                shift 2
                ;;
            -R|--recursive)
                RECURSIVE=1
                shift
                ;;
            -T|--self-test)
                SELF_TEST=1
                shift
                ;;
            -B|--no-banner)
                NO_BANNER=1
                shift
                ;;
            -v|--verbose)
                VERBOSE=1
                shift
                ;;
            -h|--help)
                if [[ $NO_BANNER -eq 0 ]]; then
                    display_header
                fi
                show_help
                ;;
            -*)
                error "Unknown option: $1\nUse -h for help"
                ;;
            *)
                if [[ -z "$SOURCE_DIR" ]]; then
                    SOURCE_DIR="$1"
                elif [[ -z "$OUTPUT_FILE" ]]; then
                    OUTPUT_FILE="$1"
                else
                    error "Unexpected argument: $1"
                fi
                shift
                ;;
        esac
    done
}

# =============================================================================
# STATE MACHINE ENGINE
# =============================================================================

# State constants
readonly STATE_INIT="INIT"
readonly STATE_TEST="TEST"
readonly STATE_VALIDATE="VALIDATE"
readonly STATE_CHRONICLE="CHRONICLE"
readonly STATE_PREPARE="PREPARE"
readonly STATE_ARCHIVE="ARCHIVE"
readonly STATE_HARDEN="HARDEN"
readonly STATE_ASSEMBLE="ASSEMBLE"
readonly STATE_FINALIZE="FINALIZE"
readonly STATE_CLEANUP="CLEANUP"
readonly STATE_EXIT="EXIT"

# Global state tracking
CURRENT_STATE="$STATE_INIT"
PREVIOUS_STATE=""
EXIT_CODE=0
SELF_TEST=0

# Grimoire Data
GRIMOIRE_DATA=""

# Provenance Chain
HASH_ARCHIVE=""
HASH_ENCRYPTED=""
HASH_FINAL=""

# State transitions
transition_to() {
    PREVIOUS_STATE="$CURRENT_STATE"
    CURRENT_STATE="$1"
    verbose "Transitioning state: $PREVIOUS_STATE -> $CURRENT_STATE"
}

# State: Initialization and Header
state_init() {
    echo ""
    if [[ $NO_BANNER -eq 0 ]]; then
        display_header
        print_color cyan "========================================"
        print_color cyan "  BigShebang Distribution Automaton"
        print_color cyan "  Version: $SCRIPT_VERSION"
        print_color cyan "========================================"
        echo ""
    fi
    transition_to "$STATE_TEST"
}

# State: Self-Diagnostic Test
state_test() {
    if [[ $SELF_TEST -eq 1 ]]; then
        info "Initiating internal self-diagnostic protocol..."
        
        local test_root
        test_root="$(mktemp -d)"
        local test_source="$test_root/source"
        local test_output="$test_root/test.sh"
        local test_extract="$test_root/extracted"
        local test_pass="DiagnosticPass123!"
        
        mkdir -p "$test_source" "$test_extract"
        echo "DIAGNOSTIC_DATA_$(date +%s)" > "$test_source/diagnostic.txt"
        
        # Internal cycle: Archive -> Encrypt -> Assemble
        local t_tar="$test_root/test.tar.gz"
        local t_enc="$test_root/test.enc"
        
        create_tar_archive "$test_source" "$t_tar" "$test_root" >/dev/null 2>&1
        PASSWORD="$test_pass" encrypt_archive "$t_tar" "$t_enc" >/dev/null 2>&1
        generate_self_extractor "$t_enc" "$test_output" >/dev/null 2>&1
        
        # Verify
        if ! "$test_output" -p "$test_pass" -d "$test_extract" -B >/dev/null 2>&1; then
            rm -rf "$test_root"
            error "Self-diagnostic failure: Extraction protocol compromised."
        fi
        
        if ! diff -r "$test_source" "$test_extract/source" >/dev/null 2>&1; then
            rm -rf "$test_root"
            error "Self-diagnostic failure: Data integrity violation."
        fi
        
        rm -rf "$test_root"
        success "Internal self-diagnostic: Protocol integrity verified."
    fi
    transition_to "$STATE_VALIDATE"
}

# State: Input Validation
state_validate() {
    validate_compress_type
    check_dependencies
    validate_source_directory
    
    # Set default output file if not specified
    if [[ -z "$OUTPUT_FILE" ]]; then
        OUTPUT_FILE="$(basename "$SOURCE_DIR").vessel.sh"
    fi
    
    # Make output path absolute
    if [[ "$OUTPUT_FILE" != /* ]]; then
        OUTPUT_FILE="$(pwd)/$OUTPUT_FILE"
    fi
    
    # Handle optional encryption
    if [[ $ENCRYPT -eq 1 ]]; then
        if [[ -z "$PASSWORD" ]]; then
            prompt_password
        fi
    else
        ENCRYPTION_CIPHER="none"
        verbose "Encryption disabled: creating passwordless archive"
    fi
    
    transition_to "$STATE_CHRONICLE"
}

# State: Chronicle (Knowledge Gathering)
state_chronicle() {
    info "Communing with the Grimoire..."
    
    local temp_grimoire="$(mktemp)"
    
    # 1. Header
    echo "# BIGSHEBANG GRIMOIRE" > "$temp_grimoire"
    echo "## Project: $(basename "$SOURCE_DIR")" >> "$temp_grimoire"
    echo "## Generated: $(date)" >> "$temp_grimoire"
    echo "" >> "$temp_grimoire"
    
    # 2. Extract Da'at (Intent)
    local daat_file=""
    if [[ -f "$SOURCE_DIR/GRIMOIRE.md" ]]; then daat_file="$SOURCE_DIR/GRIMOIRE.md"; fi
    if [[ -f "$SOURCE_DIR/DAAT.log" ]]; then daat_file="$SOURCE_DIR/DAAT.log"; fi
    
    if [[ -n "$daat_file" ]]; then
        verbose "Found Da'at entry: $daat_file"
        echo "## Da'at (Intent)" >> "$temp_grimoire"
        cat "$daat_file" >> "$temp_grimoire"
        echo "" >> "$temp_grimoire"
    fi
    
    # 3. Holographic Manifest
    echo "## Holographic Manifest" >> "$temp_grimoire"
    echo "| Path | Size | SHA-256 |" >> "$temp_grimoire"
    echo "|------|------|---------|" >> "$temp_grimoire"
    
    # Scan files (excluding hidden and .git)
    find "$SOURCE_DIR" -type f ! -path '*/.*' | while read -r f; do
        local rel_path="${f#$SOURCE_DIR/}"
        local size=$(wc -c < "$f")
        local hash=$(calculate_hash "$f")
        echo "| $rel_path | $(human_readable_size "$size") | $hash |" >> "$temp_grimoire"
    done
    
    # Encode for embedding
    GRIMOIRE_DATA=$(base64 -w 0 < "$temp_grimoire")
    rm -f "$temp_grimoire"
    
    success "Grimoire immanentized: Contextual consciousness preserved."
    transition_to "$STATE_PREPARE"
}

# State: Prepare Environment
state_prepare() {
    # Create temporary working directory
    temp_dir="$(mktemp -d)"
    tar_file="$temp_dir/archive.tar${COMPRESS_EXT[$COMPRESS_TYPE]}"
    encrypted_file="$temp_dir/archive.enc"
    
    # Get original directory size
    original_size="$(du -sb "$SOURCE_DIR" 2>/dev/null | cut -f1)"
    info "Source directory size: $(human_readable_size "$original_size")"
    
    transition_to "$STATE_ARCHIVE"
}

# State Machine Dispatcher
run_automaton() {
    trap 'transition_to "$STATE_CLEANUP"' EXIT INT TERM
    
    while [[ "$CURRENT_STATE" != "$STATE_EXIT" ]]; do
        case "$CURRENT_STATE" in
            "$STATE_INIT")      state_init ;;
            "$STATE_TEST")      state_test ;;
            "$STATE_VALIDATE")  state_validate ;;
            "$STATE_CHRONICLE") state_chronicle ;;
            "$STATE_PREPARE")   state_prepare ;;
            "$STATE_ARCHIVE")   state_archive ;;
            "$STATE_HARDEN")    state_harden ;;
            "$STATE_ASSEMBLE")  state_assemble ;;
            "$STATE_FINALIZE")  state_finalize ;;
            "$STATE_CLEANUP")   state_cleanup ;;
            *) error "Unknown state: $CURRENT_STATE" ;;
        esac
    done
}

# =============================================================================
# MAIN FUNCTION (Entry Point)
# =============================================================================

main() {
    run_automaton
}

# =============================================================================
# STATE ACTION FUNCTIONS
# =============================================================================

state_archive() {
    info "Creating distribution archive..."
    create_tar_archive "$SOURCE_DIR" "$tar_file" "$temp_dir"
    
    HASH_ARCHIVE=$(calculate_hash "$tar_file")
    verbose "Archive Hash: $HASH_ARCHIVE"
    
    local tar_size="$(wc -c < "$tar_file")"
    info "Archive size: $(human_readable_size "$tar_size")"
    
    transition_to "$STATE_HARDEN"
}

state_harden() {
    if [[ "$ENCRYPTION_CIPHER" == "none" ]]; then
        verbose "Payload hardening skipped (open distribution)"
        cp "$tar_file" "$encrypted_file"
        HASH_ENCRYPTED=$(calculate_hash "$encrypted_file")
        transition_to "$STATE_ASSEMBLE"
        return
    fi

    info "Hardening distribution vessel..."
    encrypt_archive "$tar_file" "$encrypted_file"
    
    HASH_ENCRYPTED=$(calculate_hash "$encrypted_file")
    verbose "Hardened Hash: $HASH_ENCRYPTED"
    
    local encrypted_size="$(wc -c < "$encrypted_file")"
    info "Hardened size: $(human_readable_size "$encrypted_size")"
    
    transition_to "$STATE_ASSEMBLE"
}

state_assemble() {
    info "Generating self-extracting script..."
    generate_self_extractor "$encrypted_file" "$OUTPUT_FILE"
    
    HASH_FINAL=$(calculate_hash "$OUTPUT_FILE")
    verbose "Final Script Hash: $HASH_FINAL"
    
    local final_size="$(wc -c < "$OUTPUT_FILE")"
    transition_to "$STATE_FINALIZE"
}

state_finalize() {
    local final_size="$(wc -c < "$OUTPUT_FILE")"
    
    # Summary
    echo ""
    print_color green "========================================"
    print_color green "  Automaton Execution Complete!"
    print_color green "========================================"
    echo ""
    print_color cyan "Source:          $SOURCE_DIR"
    print_color cyan "Output:          $OUTPUT_FILE"
    print_color cyan "Compression:     $COMPRESS_TYPE"
    print_color cyan "Encryption:      $ENCRYPTION_CIPHER"
    echo ""
    print_color cyan "Original size:   $(human_readable_size "$original_size")"
    print_color cyan "Final size:      $(human_readable_size "$final_size")"
    local ratio=$((final_size * 100 / original_size))
    print_color cyan "Size ratio:      ${ratio}%"
    echo ""
    print_color yellow "Provenance Chain (SHA-256):"
    print_color blue "  Original Archive: $HASH_ARCHIVE"
    print_color blue "  Transport Vessel: $HASH_ENCRYPTED"
    print_color blue "  Final Script:     $HASH_FINAL"
    echo ""
    if [[ "$ENCRYPTION_CIPHER" != "none" ]]; then
        print_color yellow "Vessel hardened. Keep your password safe - the cycle continues."
    else
        print_color green "Distribution vessel ready. Open distribution - the cycle continues."
    fi
    echo ""
    
    transition_to "$STATE_CLEANUP"
}

state_cleanup() {
    verbose "Performing final state cleanup..."
    if [[ -d "${temp_dir:-}" ]]; then
        rm -rf "$temp_dir"
    fi
    trap - EXIT INT TERM
    transition_to "$STATE_EXIT"
}

